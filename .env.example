# ==============================================================================
# Server Configuration
# ==============================================================================

# Port for the Express server to listen on
PORT=3000

# Node environment - use 'development' for local testing, 'production' for deploy
NODE_ENV=development

# ==============================================================================
# Database Configuration
# ==============================================================================

# Superuser connection string - used ONLY for running database migrations.
# This user has full database access and should only be used for administrative
# tasks like running migration scripts. The application itself should use
# DB_APP_URL with the restricted omni_app user.
DATABASE_URL=postgresql://postgres:your_password@localhost:5432/omnipay_legacy

# Restricted application user credentials - the application uses this for all
# regular operations. This user has limited permissions (see 006_permissions.sql)
# to enforce security and compliance requirements.
DB_APP_USER=omni_app
DB_APP_PASSWORD=your_strong_password_here

# Application database connection string - uses the restricted omni_app user.
# This is the connection string the application should use at runtime.
DB_APP_URL=postgresql://omni_app:your_password@localhost:5432/omnipay_legacy

# ==============================================================================
# JWT Authentication
# ==============================================================================

# Secret for signing access tokens (short-lived, typically 15-60 minutes).
# Generate a strong random string - recommended 64 characters or longer.
# In production, use a proper secrets management solution.
JWT_ACCESS_SECRET=your_64_character_random_string_here

# Secret for signing refresh tokens (long-lived, typically 7-30 days).
# MUST be different from JWT_ACCESS_SECRET for security.
# Generate a separate strong random string.
JWT_REFRESH_SECRET=different_64_character_random_string_here

# ==============================================================================
# CORS Configuration
# ==============================================================================

# Allowed origins for Cross-Origin Resource Sharing.
# Use the frontend development server URL during development.
CORS_ORIGIN=http://localhost:5173
